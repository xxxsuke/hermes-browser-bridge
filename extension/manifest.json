{
  "manifest_version": 3,
  "name": "Hermes Browser Bridge",
  "version": "1.2.0",
  "description": "Hermes AI Agent 浏览器控制。Offscreen 持久连接架构。",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "bookmarks",
    "history",
    "downloads",
    "debugger",
    "browsingData",
    "fontSettings",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Hermes Bridge"
  }
}
